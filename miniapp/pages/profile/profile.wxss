/* 个人页样式 */
.profile-wechat { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.avatar-lg {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: var(--green); color: var(--gold);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; font-weight: 700;
  margin-bottom: 16rpx;
}
.profile-nickname { font-size: 34rpx; font-weight: 600; }
.profile-phone { font-size: 26rpx; color: var(--gray-400); margin-top: 8rpx; margin-bottom: 16rpx; }

/* 手机号行：修复输入框被压缩 */
.phone-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.phone-row .form-input {
  flex: 1;
  min-width: 0;
  width: auto;
}

/* 修复 picker 文字显示不全 */
picker .form-input {
  padding: 22rpx 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 修复输入框文字被裁剪 */
page .form-input {
  line-height: 1.4;
  height: auto;
  min-height: 88rpx;
}

.owner-info { display: flex; justify-content: space-between; align-items: center; }
.owner-info text { font-size: 26rpx; color: var(--gray-600); }
