<view class="container">
  <!-- ===== 未登录 ===== -->
  <view wx:if="{{!loggedIn}}" class="login-gate">
    <view class="card" style="text-align:center;padding:60rpx 28rpx">
      <view style="font-size:80rpx;margin-bottom:20rpx">🀄</view>
      <view style="font-size:36rpx;font-weight:700;color:var(--green)">麻将排桌</view>
      <view style="font-size:26rpx;color:var(--gray-400);margin:16rpx 0 40rpx">登录后即可加入牌桌</view>
      <button class="btn btn-gold btn-block" bindtap="wechatLoginBtn" disabled="{{loginLoading}}">
        {{loginLoading ? '登录中...' : '微信登录'}}
      </button>
    </view>
  </view>

  <!-- ===== 已登录 ===== -->
  <view wx:else>
    <!-- 用户信息卡片 -->
    <view class="card">
      <view class="profile-header">
        <view class="avatar-lg">{{formNickname.charAt(0)}}</view>
        <view class="profile-meta">
          <text class="profile-name">{{formNickname}}</text>
          <text class="profile-phone">{{formPhone || '未绑定手机号'}}</text>
        </view>
      </view>
    </view>

    <!-- 个人信息表单 -->
    <view class="card">
      <view class="form-group">
        <text class="form-label">昵称 <text style="color:var(--red)">*</text></text>
        <input class="form-input" placeholder="输入昵称" value="{{formNickname}}" bindinput="onNicknameInput"/>
      </view>
      <view class="form-group">
        <text class="form-label">手机号 <text style="color:var(--red)">*</text></text>
        <view class="phone-row">
          <input class="form-input" type="tel" placeholder="输入手机号" value="{{formPhone}}" bindinput="onPhoneInput" style="flex:1"/>
          <button class="btn btn-sm btn-secondary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" style="flex-shrink:0">获取</button>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">微信号（选填）</text>
        <input class="form-input" placeholder="输入微信号" value="{{formWechat}}" bindinput="onWechatInput"/>
      </view>
      <view class="form-group">
        <text class="form-label">联系方式可见性</text>
        <picker mode="selector" range="{{privacyOptions}}" range-key="name" value="{{privacyIdx}}" bindchange="onPrivacyChange">
          <view class="form-input">{{privacyText}}</view>
        </picker>
        <text class="form-hint">同局模式下，只有同一牌桌的玩家可以查看你的联系方式</text>
      </view>
      <button class="btn btn-primary btn-block" bindtap="saveProfile">保存</button>
    </view>

    <!-- 底部操作 -->
    <view class="card" style="margin-top:20rpx">
      <button class="btn btn-secondary btn-block" bindtap="logout" style="color:var(--red)">退出登录</button>
    </view>

    <!-- 老板退出 -->
    <view wx:if="{{hasOwner}}" class="card" style="margin-top:20rpx">
      <view class="owner-info">
        <text>老板：{{ownerName}}</text>
        <button class="btn btn-sm btn-danger" bindtap="logoutOwner">退出老板账号</button>
      </view>
    </view>
  </view>
</view>
