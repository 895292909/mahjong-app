/* 全局样式 - 中国传统麻将配色 */
page {
  --green: #2d5016;
  --green-light: #4a7c2e;
  --green-dark: #1a320e;
  --gold: #d4a574;
  --gold-light: #e8c9a6;
  --gold-dark: #b8864e;
  --red: #c41e3a;
  --red-light: #e84a5f;
  --cream: #f5efe6;
  --cream-dark: #e8dccc;
  --white: #fff;
  --gray-50: #faf8f5;
  --gray-100: #f0ece6;
  --gray-200: #ddd6cc;
  --gray-400: #a89888;
  --gray-600: #6b5d4e;
  --gray-800: #3d3228;
  --shadow: 0 2rpx 12rpx rgba(45, 80, 22, 0.12);
  --radius: 12px;
  --radius-lg: 16px;

  background-color: var(--cream);
  color: var(--gray-800);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow);
  margin-bottom: 20rpx;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 0;
  border-radius: 10px;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}
.btn-primary {
  background: var(--green);
  color: var(--white);
}
.btn-gold {
  background: var(--gold);
  color: var(--green-dark);
}
.btn-secondary {
  background: var(--gray-100);
  color: var(--gray-600);
}
.btn-danger {
  background: var(--red);
  color: var(--white);
}
.btn-block {
  width: 100%;
}
.btn-sm {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  display: inline-flex;
}

/* 表单 */
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--gray-600);
  margin-bottom: 8rpx;
  display: block;
}
.form-input {
  width: 100%;
  padding: 22rpx 28rpx;
  border: 1.5px solid var(--gray-200);
  border-radius: 10px;
  font-size: 28rpx;
  background: var(--gray-50);
  box-sizing: border-box;
}
.form-hint {
  font-size: 24rpx;
  color: var(--gray-400);
  margin-top: 8rpx;
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20px;
  font-size: 24rpx;
  font-weight: 600;
}
.tag-waiting { background: #fff8e1; color: #f57f17; }
.tag-playing { background: #fce4ec; color: #c62828; }
.tag-finished { background: #e8eaf6; color: #37474f; }

/* 加载 + 动画 */
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: var(--gray-400);
  font-size: 26rpx;
}
.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--green);
  border-radius: 50%;
  animation: spin .6s linear infinite;
  margin: 0 auto 16rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.hall-card, .table-card, .monitor-table {
  animation: fadeInUp .3s ease both;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: var(--gray-400);
}
